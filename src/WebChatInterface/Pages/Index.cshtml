@page
@model WebChatInterface.Pages.IndexModel
@{
    ViewData["Title"] = "Chat Interface";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">
            <h1>Multi-Agent Chat Interface</h1>
            <p class="lead">Chat with NeMo Data Analysis and MAF Action agents</p>
            
            <!-- Chat Messages Area -->
            <div class="card mb-4 chat-container" id="chatScroll">
                <div class="card-body" id="chatMessages">
                    <p class="text-muted text-center chat-placeholder">Chat history will appear here...</p>
                </div>
            </div>

            <!-- Chat Input Area -->
            <div class="input-group mb-3">
                <input type="text" class="form-control" id="messageInput" placeholder="Type your message..." />
                <button class="btn btn-primary" type="button" id="sendBtn">Send</button>
            </div>

            <!-- Predefined Questions -->
            <div class="mb-4">
                <label class="form-label"><strong>Quick Test Questions:</strong></label>
                <div class="btn-group-vertical w-100" role="group">
                    <button type="button" class="btn btn-outline-secondary text-start predefined-btn" data-question="Analyze quarterly revenue trends">
                        📊 Analyze quarterly revenue trends
                    </button>
                    <button type="button" class="btn btn-outline-secondary text-start predefined-btn" data-question="Detect anomalies in system performance">
                        ⚠️ Detect anomalies in system performance
                    </button>
                    <button type="button" class="btn btn-outline-secondary text-start predefined-btn" data-question="Generate monthly metrics report">
                        📈 Generate monthly metrics report
                    </button>
                    <button type="button" class="btn btn-outline-secondary text-start predefined-btn" data-question="Trigger alert for high CPU usage">
                        🚨 Trigger alert for high CPU usage
                    </button>
                    <button type="button" class="btn btn-outline-secondary text-start predefined-btn" data-question="Compare year-over-year growth">
                        📉 Compare year-over-year growth
                    </button>
                    <button type="button" class="btn btn-outline-secondary text-start predefined-btn" data-question="What insights can you provide about recent data trends?">
                        💡 What insights can you provide about recent data trends?
                    </button>
                    <button type="button" class="btn btn-outline-secondary text-start predefined-btn" data-question="Send a report to the analytics team">
                        📧 Send a report to the analytics team
                    </button>
                    <button type="button" class="btn btn-outline-secondary text-start predefined-btn" data-question="Check agent availability and health status">
                        🏥 Check agent availability and health status
                    </button>
                </div>
            </div>

            <!-- Service Status -->
            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">Service Status</div>
                        <div class="card-body">
                            <small id="serviceStatus" class="text-muted">Loading...</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">Configuration</div>
                        <div class="card-body">
                            <small id="configStatus" class="text-muted">
                                NeMo URL: <span id="nemoEndpoint">-</span><br/>
                                MAF URL: <span id="mafEndpoint">-</span>
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const chatScrollDiv = document.getElementById('chatScroll');
        const chatMessagesDiv = document.getElementById('chatMessages');
        const messageInput = document.getElementById('messageInput');
        const sendBtn = document.getElementById('sendBtn');
        const predefinedBtns = document.querySelectorAll('.predefined-btn');

        // Handle send button click
        sendBtn.addEventListener('click', () => sendMessage());
        messageInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        // Handle predefined questions
        predefinedBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const question = btn.getAttribute('data-question');
                messageInput.value = question;
                messageInput.focus();
            });
        });

        async function sendMessage() {
            const message = messageInput.value.trim();
            if (!message) return;

            // Add user message to chat
            addMessageToChat('user', 'You', message, new Date());
            messageInput.value = '';

            try {
                // Send to backend
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message })
                });

                if (response.ok) {
                    const data = await response.json();
                    const responder = data.respondedBy || 'Agent';
                    addMessageToChat('agent', responder, data.content || 'No response', data.responseTime);
                    
                    if (data.analysisInsights && data.analysisInsights.length > 0) {
                        addMessageToChat('system', 'System', 'Insights: ' + data.analysisInsights.join(', '), new Date());
                    }
                } else {
                    addMessageToChat('system', 'System', 'Error: ' + response.statusText, new Date());
                }
            } catch (error) {
                addMessageToChat('system', 'System', 'Error: ' + error.message, new Date());
            }
        }

        function addMessageToChat(role, actor, content, timestamp) {
            const placeholder = chatMessagesDiv.querySelector('.chat-placeholder');
            if (placeholder) {
                placeholder.remove();
            }

            const rowEl = document.createElement('div');
            rowEl.className = `chat-row ${role === 'user' ? 'chat-row-user' : 'chat-row-other'}`;

            const timestampText = formatTimestamp(timestamp);
            const roleBadgeClass = role === 'user' ? 'chat-role-user' : (role === 'agent' ? 'chat-role-agent' : 'chat-role-system');

            rowEl.innerHTML = `
                <div class="chat-bubble ${role === 'user' ? 'chat-bubble-user' : 'chat-bubble-other'}">
                    <div class="chat-meta">
                        <span class="chat-role ${roleBadgeClass}">${escapeHtml(actor)}</span>
                        <span class="chat-timestamp">${escapeHtml(timestampText)}</span>
                    </div>
                    <div class="chat-content">${escapeHtml(content)}</div>
                </div>
            `;

            chatMessagesDiv.appendChild(rowEl);
            chatScrollDiv.scrollTop = chatScrollDiv.scrollHeight;
        }

        function formatTimestamp(timestamp) {
            const date = timestamp ? new Date(timestamp) : new Date();
            if (Number.isNaN(date.getTime())) {
                return new Date().toLocaleString();
            }

            return date.toLocaleString();
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Load service status
        async function loadServiceStatus() {
            try {
                const response = await fetch('/api/agents/discovery');
                if (response.ok) {
                    const services = await response.json();
                    const statusHtml = services.map(s => 
                        `<span class="badge ${s.status === 'Running' ? 'bg-success' : 'bg-danger'}">${s.serviceName}: ${s.status}</span>`
                    ).join(' ');
                    document.getElementById('serviceStatus').innerHTML = statusHtml || 'No services found';
                    loadConfigStatus(services);
                }
            } catch (error) {
                document.getElementById('serviceStatus').innerHTML = 'Error loading status: ' + error.message;
                loadConfigStatus([]);
            }
        }

        function loadConfigStatus(services) {
            const nemoService = services.find(s => s.serviceName && s.serviceName.toLowerCase().includes('nemo'));
            const mafService = services.find(s => s.serviceName && s.serviceName.toLowerCase().includes('maf'));

            setEndpoint('nemoEndpoint', nemoService ? nemoService.endpoint : null);
            setEndpoint('mafEndpoint', mafService ? mafService.endpoint : null);
        }

        function setEndpoint(elementId, endpoint) {
            const element = document.getElementById(elementId);
            if (!element) {
                return;
            }

            if (endpoint) {
                element.innerHTML = `<a href="${escapeHtml(endpoint)}" target="_blank" rel="noopener noreferrer">${escapeHtml(endpoint)}</a>`;
            } else {
                element.textContent = 'Unavailable';
            }
        }

        // Initialize
        loadServiceStatus();
        setInterval(loadServiceStatus, 10000); // Refresh every 10 seconds
    </script>
    <style>
        .predefined-btn {
            border: 1px solid #dee2e6;
            text-align: left;
            padding: 10px;
            margin-bottom: 5px;
            transition: all 0.3s ease;
        }
        .predefined-btn:hover {
            background-color: #f8f9fa;
            border-color: #007bff;
        }
        .btn-group-vertical {
            display: flex;
            flex-direction: column;
        }
        .chat-container {
            height: 400px;
            overflow-y: auto;
        }
        .chat-row {
            display: flex;
            margin-bottom: 12px;
        }
        .chat-row-user {
            justify-content: flex-end;
        }
        .chat-row-other {
            justify-content: flex-start;
        }
        .chat-bubble {
            max-width: 78%;
            padding: 10px 12px;
            border-radius: 12px;
            border: 1px solid #dee2e6;
        }
        .chat-bubble-user {
            background-color: #e8f0ff;
            border-color: #b8cdfa;
        }
        .chat-bubble-other {
            background-color: #f8f9fa;
            border-color: #d7dce0;
        }
        .chat-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 6px;
        }
        .chat-role {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }
        .chat-role-user {
            color: #2f61c6;
        }
        .chat-role-agent {
            color: #1f8a55;
        }
        .chat-role-system {
            color: #8b6a12;
        }
        .chat-timestamp {
            color: #6c757d;
            font-size: 0.75rem;
            white-space: nowrap;
        }
        .chat-content {
            white-space: pre-wrap;
            word-wrap: break-word;
        }
    </style>
}
